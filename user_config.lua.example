-- 用户配置模板
-- 复制此文件为 user_config.lua 并根据需要修改

-- 选择预设配置作为基础
local base_config = require("presets.default")

-- 您的自定义配置将覆盖预设配置
local user_config = {
    -- ============================================
    -- 外观配置
    -- ============================================
    appearance = {
        -- 主题选择: tokyo_night, dracula, catppuccin
        theme = "tokyo_night",

        -- 自定义颜色（可选）
        custom_colors = {
            -- 例如：background = "#1a1b26",
        },

        -- 字体配置
        font = {
            font_family = "JetBrains Mono",
            weight = "Regular",
            font_size = 11.0,
        },

        -- 背景配置
        background = {
            enabled = false,  -- 启用背景图片
            -- 如果启用，可以配置：
            -- type = "image",
            -- image_path = "your-image.png",  -- 放在pictures目录
            -- opacity = 0.8,
        },

        -- 窗口配置
        window = {
            padding_left = 10,
            padding_right = 10,
            padding_top = 10,
            padding_bottom = 10,
        },
    },

    -- ============================================
    -- 快捷键配置
    -- ============================================
    keybindings = {
        -- Leader模式（类似Vim的前缀键）
        leader = {
            enabled = true,
            key = "Space",
            mods = "CTRL",
        },

        -- 自定义快捷键（会覆盖默认快捷键）
        custom_keys = {
            -- 示例：快速打开编辑器
            -- {
            --     key = "e",
            --     mods = "CTRL|SHIFT",
            --     action = wezterm.action.SpawnCommandInNewTab({
            --         args = { "vim" }
            --     }),
            -- },
        },
    },

    -- ============================================
    -- Shell配置
    -- ============================================
    shell = {
        enabled = true,
        -- default_shell = "/bin/zsh",  -- 留空自动检测

        -- 环境变量
        env_vars = {
            -- EDITOR = "vim",
            -- LANG = "en_US.UTF-8",
        },

        -- 项目特定Shell配置
        projects = {
            -- {
            --     path = "/path/to/project",
            --     shell = "/bin/bash",
            -- },
        },
    },

    -- ============================================
    -- SSH配置
    -- ============================================
    ssh = {
        enabled = true,
        -- config_path = "~/.ssh/config",
    },

    -- ============================================
    -- 性能配置
    -- ============================================
    performance = {
        enable_startup_optimization = true,
        max_fps = 60,
        max_scrollback_lines = 10000,
    },

    -- ============================================
    -- 插件配置
    -- ============================================
    plugins = {
        -- "smart_move",
        -- "url_highlight",
    },
}

-- 合并配置
local core = require("ghost.core.init")
return core.merge_config(base_config, user_config)
